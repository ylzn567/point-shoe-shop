<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Point Shoe Shop</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Palatino Linotype', 'Book Antiqua', Palatino, serif;
            line-height: 1.6;
            color: #2b2b2b;
            background: #f7f0f3;
            min-height: 100vh;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        .hero {
            background: #ffffff;
            border-radius: 10px;
            padding: 60px 40px;
            text-align: center;
            border: 1px solid #e4d3db;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
            margin-top: 40px;
        }
        h1 {
            font-family: 'Lucida Calligraphy', 'Segoe Script', 'Brush Script MT', cursive;
            color: #2b2b2b;
            font-size: 2.8em;
            margin-bottom: 12px;
            letter-spacing: 0.3px;
        }
        .hero p {
            font-size: 1.1em;
            color: #5d5056;
            margin-bottom: 30px;
        }
        .hero-buttons {
            display: flex;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
        }
        .btn {
            padding: 15px 30px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1.05em;
            font-weight: bold;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }
        .btn-primary {
            background: #9b6b7c;
            color: white;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(155, 107, 124, 0.35);
        }
        .btn-secondary {
            background: #ffffff;
            color: #2b2b2b;
            border: 2px solid #d7c2cb;
        }
        .btn-secondary:hover {
            background: #f2e6ec;
            transform: translateY(-2px);
        }
        .features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 50px;
        }
        .feature-card {
            background: #ffffff;
            padding: 28px;
            border-radius: 8px;
            text-align: center;
            border: 1px solid #e4d3db;
            box-shadow: 0 5px 16px rgba(0, 0, 0, 0.05);
            transition: transform 0.3s ease;
        }
        .feature-card:hover {
            transform: translateY(-5px);
        }
        .feature-card h3 {
            font-family: 'Lucida Calligraphy', 'Segoe Script', 'Brush Script MT', cursive;
            color: #2b2b2b;
            margin-bottom: 8px;
            font-size: 1.2em;
        }
    </style>
</head>
<body>
    <%- include('partials/nav') %>
    
    <div class="container">
        <div class="hero">
            <h1>Point Shoe Shop</h1>
            <p>Your Premier Destination for Professional Ballet Point Shoes</p>
            <div class="hero-buttons">
                <a href="/shoes-view" class="btn btn-primary">Browse the Collection</a>
                <a href="/users-view" class="btn btn-secondary">View Users</a>
            </div>
        </div>

        <div class="features">
            <div class="feature-card">
                <h3>Premium Quality</h3>
                <p>Only the finest professional ballet shoes from trusted brands.</p>
            </div>
            <div class="feature-card">
                <h3>Fast Delivery</h3>
                <p>Quick processing and shipping for urgent orders.</p>
            </div>
            <div class="feature-card">
                <h3>Expert Selection</h3>
                <p>Handpicked shoes tailored to professional dancers.</p>
            </div>
        </div>
    </div>
</body>
</html>